<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_LKS2.Pages.Register"
             Title="Register">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    
    <Grid
        RowDefinitions="Auto, *">

        <VerticalStackLayout 
            Spacing="50" 
            VerticalOptions="Center" 
            Grid.Row="1">

            <Label
                Text="Register"
                FontSize="Title" 
                HorizontalTextAlignment="Center" />

            <VerticalStackLayout 
                Spacing="25">

                <Entry 
                    x:Name="EmailEntry"
                    Placeholder="E-Mail..." 
                    WidthRequest="350" />

                <HorizontalStackLayout
                    HorizontalOptions="Center" 
                    WidthRequest="350" 
                    Spacing="25">

                    <Entry 
                        x:Name="PasswordEntry"
                        Placeholder="Password..." 
                        IsPassword="True" 
                        WidthRequest="275" />

                    <Button 
                        x:Name="PasswordShow"
                        Text="👁️" 
                        Clicked="OnEyeBtnClicked"
                        BackgroundColor="{StaticResource Custom1}" />

                </HorizontalStackLayout>

                <HorizontalStackLayout
                    HorizontalOptions="Center" 
                    WidthRequest="350" 
                    Spacing="25">

                    <Entry 
                        x:Name="PasswordEntryConf"
                        Placeholder="Confirm Password..." 
                        IsPassword="True" 
                        WidthRequest="275" />

                    <Button 
                        x:Name="PasswordShowConf"
                        Text="👁️" 
                        Clicked="OnEyeBtnClickedConf"
                        BackgroundColor="{StaticResource Custom1}" />

                </HorizontalStackLayout>

                <Button 
                    Text="Already have an account" 
                    TextColor="Grey"
                    Clicked="OnLoginBtnClicked"
                    BackgroundColor="Transparent" 
                    Padding="0"
                    MinimumHeightRequest="0"
                    MinimumWidthRequest="0" />

                <!-- Debugging purpose -->
                <HorizontalStackLayout HorizontalOptions="Center">
                    <CheckBox x:Name="AdminCheckBox" />
                    <Label Text="Register as Admin" VerticalOptions="Center" />
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <Button 
                x:Name="RegisterBtn"
                Text="Register" 
                Clicked="OnRegisterBtnClicked"
                TextColor="White"
                BackgroundColor="{StaticResource Custom1}" 
                WidthRequest="100"
                IsEnabled="False" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>