<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_LKS2.Intro">

    <Grid>
        <Image
            Source="background.jpg"
            Aspect="AspectFill" />
        
        <ScrollView>
            <Grid 
                RowDefinitions="Auto, *"
                Margin="100" >

                <VerticalStackLayout
                    Spacing="50" 
                    Grid.Row="1" 
                    VerticalOptions="Center" >
                  
                    <Label
                        Text="Welcome to MAUILKS!"
                        Style="{StaticResource SubHeadline}" />

                    <Button
                        Text="Continue"
                        Clicked="OnBtnClicked"
                        WidthRequest="150" />

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>